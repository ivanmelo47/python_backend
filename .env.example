APP_NAME=Python Backend API
APP_VERSION=1.0.0
DEBUG=true
APP_TIMEZONE=America/Mexico_City
JWT_SECRET_KEY=super-secret-change-me-with-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=http://localhost:3000

# Option A: full URL override (if set, DB_* is ignored)
# DATABASE_URL=sqlite:///./app.db

# Option B: discrete DB params (recommended for local development)
DB_SCHEME=mariadb+mariadbconnector
DB_HOST=localhost
DB_PORT=3309
DB_DATABASE=python_backend
DB_USERNAME=root
DB_PASSWORD=140735
DB_TIMEZONE=-06:00

# MySQL example
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/mydb

# MariaDB example
# DATABASE_URL=mariadb+mariadbconnector://root:password@localhost:3306/mydb

# SQL Server example
# DATABASE_URL=mssql+pyodbc://sa:YourStrong!Passw0rd@localhost:1433/mydb?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
